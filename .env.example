# FamilyHub runtime config — copy to `.env` and fill in.
#   cp .env.example .env
#
# ONLY the Supabase anon key + project URL. FamilyHub is read-mostly (anon +
# RLS). A service_role key here is a stop signal (CONTRACT §5) — never add one.
# The real .env is gitignored; secrets never live in git (ARCH-RULE-001).

SUPABASE_URL=
SUPABASE_ANON_KEY=
